# ============================================================
# PolyVAR .gitignore
# R package repository -- what NOT to track in git
# ============================================================

# ── R session artefacts ──────────────────────────────────────
.Rhistory
.Rapp.history
.RData
.Ruserdata
.Rproj.user/
*.Rproj

# ── Compiled objects (built locally, not portable) ───────────
src/*.o
src/*.so
src/*.dll
src/*.a
src/*.dylib

# NOTE: DO NOT add these -- they must be committed:
# src/RcppExports.cpp   <-- generated by Rcpp::compileAttributes(), must be in repo
# R/RcppExports.R       <-- generated by Rcpp::compileAttributes(), must be in repo
# src/Makevars          <-- build instructions, must be in repo
# src/Makevars.win      <-- Windows build instructions, must be in repo

# ── R CMD check output ───────────────────────────────────────
*.Rcheck/
polyvar.Rcheck/

# ── Package build outputs (don't commit tarballs to the tree) ─
*.tar.gz
*.zip

# ── R package install cache ──────────────────────────────────
po/*.gmo

# ── macOS system files ───────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverrideIcon
._*

# ── Windows system files ─────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Linux system files ───────────────────────────────────────
*~
.fuse_hidden*
.Trash-*

# ── IDE and editor files ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── pkgdown website (if auto-generated) ──────────────────────
#docs/

# ── Test output and temporary files ─────────────────────────
tests/testthat/_snaps/
inst/demo/polyvar_demo/
polyvar_results/
demo_results/
cli_test_out/
